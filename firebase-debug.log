[debug] [2025-09-03T12:08:06.222Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n    match /databases/{database}/documents {\n\n          // Helper function to check if a user is an admin\n              function isAdmin(userId) {\n                      return exists(/databases/$(database)/documents/operators/$(userId)) &&\n                                   get(/databases/$(database)/documents/operators/$(userId)).data.role == 'admin';\n              }\n\n                  // Helper function to check if a user is authenticated\n                      function isAuthenticated() {\n                              return request.auth != null;\n                      }\n                          \n                              // Helper function to get user role\n                                  function getUserRole(userId) {\n                                          return get(/databases/$(database)/documents/operators/$(userId)).data.role;\n                                  }\n\n                                      // Deny all access by default\n                                          match /{document=**} {\n                                                  allow read, write: if false;\n                                          }\n                                              \n                                                  // Operators collection\n                                                      match /operators/{operatorId} {\n                                                              // Admins can read/write any operator\n                                                                    // A user can read/update their own profile\n                                                                          allow read, update: if isAdmin(request.auth.uid) || request.auth.uid == get(/databases/$(database)/documents/operators/$(operatorId)).data.uid;\n                                                                                // Admins can create/delete operators\n                                                                                      allow create, delete: if isAdmin(request.auth.uid);\n                                                      }\n                                                          \n                                                              // Configuration collections (like departmentMap, workPhaseTemplates, etc.)\n                                                                  match /configuration/{docId} {\n                                                                          allow read: if isAuthenticated();\n                                                                                allow write: if isAdmin(request.auth.uid);\n                                                                  }\n                                                                      \n                                                                          match /workPhaseTemplates/{docId} {\n                                                                                    allow read: if isAuthenticated();\n                                                                                            allow write: if isAdmin(request.auth.uid);\n                                                                          }\n                                                                              \n                                                                                   match /workstations/{docId} {\n                                                                                            allow read: if isAuthenticated();\n                                                                                                    allow write: if isAdmin(request.auth.uid);\n                                                                                   }\n\n                                                                                       match /workCycles/{docId} {\n                                                                                                allow read: if isAuthenticated();\n                                                                                                        allow write: if isAdmin(request.auth.uid);\n                                                                                       }\n\n                                                                                           // JobOrders collection\n                                                                                               match /jobOrders/{jobId} {\n                                                                                                      // Any authenticated user can read job orders\n                                                                                                            allow read: if isAuthenticated();\n                                                                                                                  // Only admins can create/delete job orders. \n                                                                                                                        // Operators update them via server actions which run with admin privileges implicitly.\n                                                                                                                              allow create, delete: if isAdmin(request.auth.uid);\n                                                                                                                                    // Operators can update jobs, but this should be tightened further\n                                                                                                                                          // to only allow specific field updates (e.g., status, phases).\n                                                                                                                                                // For now, allow any authenticated user to update.\n                                                                                                                                                      allow update: if isAuthenticated();\n                                                                                               }\n                                                                                                   \n                                                                                                       // RawMaterials collection\n                                                                                                           match /rawMaterials/{materialId} {\n                                                                                                                  allow read: if isAuthenticated();\n                                                                                                                        // Only admins can create new material definitions or delete them.\n                                                                                                                              allow create, delete: if isAdmin(request.auth.uid);\n                                                                                                                                    // Any authenticated user can update (e.g., add a batch, which updates stock)\n                                                                                                                                          allow update: if isAuthenticated();\n                                                                                                           }\n                                                                                                               \n                                                                                                                   // MaterialWithdrawals collection\n                                                                                                                       match /materialWithdrawals/{withdrawalId} {\n                                                                                                                              allow read: if isAuthenticated();\n                                                                                                                                    // Only authenticated users can create withdrawals (this is done via server actions)\n                                                                                                                                          allow create: if isAuthenticated();\n                                                                                                                                                // Only admins can delete withdrawal history\n                                                                                                                                                      allow delete: if isAdmin(request.auth.uid);\n                                                                                                                       }\n                                                                                                                           \n                                                                                                                               // NonConformityReports collection\n                                                                                                                                   match /nonConformityReports/{reportId} {\n                                                                                                                                           allow read, create: if isAuthenticated();\n                                                                                                                                                  allow update, delete: if isAdmin(request.auth.uid);\n                                                                                                                                   }\n\n                                                                                                                                       // Counters collection (for ODLs)\n                                                                                                                                           match /counters/{counterId} {\n                                                                                                                                                    allow read: if isAuthenticated();\n                                                                                                                                                            allow write: if isAdmin(request.auth.uid);\n                                                                                                                                           }\n    }\n}\n\n                                                                                                                                           }\n                                                                                                                                   }\n                                                                                                                       }\n                                                                                                           }\n                                                                                               }\n                                                                                       }\n                                                                                   }\n                                                                          }\n                                                                  }\n                                                      }\n                                          }\n                                  }\n                      }\n              }\n    }\n}"}]}}
