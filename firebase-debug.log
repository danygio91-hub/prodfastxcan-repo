[debug] [2025-09-05T09:43:14.945Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if a user is an admin or supervisor\n    function isAdmin(userId) {\n      return get(/databases/$(database)/documents/operators/$(userId)).data.role in ['admin', 'supervisor'];\n    }\n\n    // Helper function to check if a user is logged in\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    // Operators can be read by any signed-in user, but only modified by admins or themselves.\n    match /operators/{userId} {\n      allow read: if isSignedIn();\n      allow create, update: if isAdmin(request.auth.uid);\n      allow delete: if isAdmin(request.auth.uid);\n    }\n    \n    // Only signed-in users can access job orders\n    match /jobOrders/{jobId} {\n        allow read, write: if isSignedIn();\n    }\n\n    // Raw materials can be read by signed-in users, but only modified by admins/supervisors\n    match /rawMaterials/{materialId} {\n        allow read: if isSignedIn();\n        allow create, update, delete: if isAdmin(request.auth.uid);\n    }\n\n    // Withdrawals can be read by signed-in users, but only created/modified by them, and only deleted by admins\n     match /materialWithdrawals/{withdrawalId} {\n      allow read, create: if isSignedIn();\n      allow update: if isSignedIn(); // Operator can update their own work\n      allow delete: if isAdmin(request.auth.uid);\n    }\n    \n    // Configuration can be read by anyone signed in, but only written by admins.\n    match /configuration/{configId} {\n        allow read: if isSignedIn();\n        allow write: if isAdmin(request.auth.uid);\n    }\n    \n    // Workstations and templates can be read by anyone signed in, written by admins\n    match /{collection}/{docId} \n      where collection in ['workstations', 'workPhaseTemplates', 'workCycles', 'departments', 'packaging'] {\n        allow read: if isSignedIn();\n        allow write: if isAdmin(request.auth.uid);\n    }\n    \n    // System settings can only be accessed by admins\n    match /system/{docId} {\n        allow read, write: if isAdmin(request.auth.uid);\n    }\n    \n     // Problem reports can be created by any signed-in user, but only managed by admin/supervisor\n    match /productionProblemReports/{reportId} {\n      allow create: if isSignedIn();\n      allow read, update, delete: if isAdmin(request.auth.uid);\n    }\n    \n    // Non-conformity reports can be created by any signed-in user, but only managed by admin/supervisor\n    match /nonConformityReports/{reportId} {\n      allow create: if isSignedIn();\n      allow read, update, delete: if isAdmin(request.auth.uid);\n    }\n\n  }\n}\n"}]}}
