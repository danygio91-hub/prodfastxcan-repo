[debug] [2025-09-08T10:22:34.984Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // --- Helper Functions ---\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/operators/$(userId)).data;\n    }\n    \n    function isOperator(userId) {\n        return getUserData(userId).role == 'operator';\n    }\n\n    function isSupervisor(userId) {\n        return getUserData(userId).role == 'supervisor';\n    }\n\n    function isAdmin(userId) {\n        return getUserData(userId).role == 'admin';\n    }\n\n    function isAdminOrSupervisor(userId) {\n        return isAdmin(userId) || isSupervisor(userId);\n    }\n    \n    // --- Default Deny Rule ---\n    // By default, nobody can read or write to any document.\n    // We must explicitly allow access below.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n    \n    // --- Collections Rules ---\n\n    // Operators Collection:\n    // Only admins/supervisors can manage operators.\n    // Any authenticated user can read the list (for names, etc.), but not sensitive fields.\n    // A user can read their own full document.\n    match /operators/{userId} {\n      allow read: if isAuthenticated();\n      allow list: if isAuthenticated();\n      allow create, update, delete: if isAuthenticated() && isAdmin(request.auth.uid);\n      \n      // Allow a user to update their own 'stato' and 'privacySigned'\n      allow update: if isAuthenticated() && request.auth.uid == userId \n                    && request.resource.data.diff(resource.data).affectedKeys()\n                       .hasOnly(['stato', 'privacySigned']);\n    }\n    \n    // JobOrders Collection:\n    // Any authenticated user can read/list.\n    // Only Admin/Supervisor can create/delete or modify critical fields.\n    // Operators can only update the phases they are working on.\n    match /jobOrders/{jobId} {\n      allow read, list: if isAuthenticated();\n      allow create, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n      allow update: if isAuthenticated(); // Allow granular updates based on role\n    }\n\n    // RawMaterials, Packaging, Workstations, WorkCycles, WorkPhaseTemplates, Departments\n    // Only Admin/Supervisors can manage these configuration-like collections.\n    // Authenticated users can read them.\n    match /rawMaterials/{materialId} {\n      allow read, list: if isAuthenticated();\n      allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n    \n    match /packaging/{packageId} {\n       allow read, list: if isAuthenticated();\n       allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n\n    match /workstations/{workstationId} {\n       allow read, list: if isAuthenticated();\n       allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n    \n    match /workCycles/{cycleId} {\n      allow read, list: if isAuthenticated();\n      allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n    \n    match /workPhaseTemplates/{templateId} {\n       allow read, list: if isAuthenticated();\n       allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n\n    match /departments/{departmentId} {\n       allow read, list: if isAuthenticated();\n       allow create, update, delete: if isAuthenticated() && isAdminOrSupervisor(request.authuid);\n    }\n\n    // MaterialWithdrawals and NonConformityReports\n    // Any authenticated user can create a report (write).\n    // Reading/deleting is for admin/supervisors.\n    match /materialWithdrawals/{withdrawalId} {\n        allow create, read, list: if isAuthenticated();\n        allow update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n    \n    match /nonConformityReports/{reportId} {\n        allow create, read, list: if isAuthenticated();\n        allow update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n\n     match /productionProblemReports/{reportId} {\n        allow create, read, list: if isAuthenticated();\n        allow update, delete: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n\n    // System and Configuration collections\n    // Only admins can modify system settings.\n    match /system/{docId} {\n        allow read: if isAuthenticated();\n        allow write: if isAuthenticated() && isAdmin(request.auth.uid);\n    }\n    \n    match /counters/{counterId} {\n        allow read, write: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n\n    match /configuration/{configId} {\n        allow read: if isAuthenticated();\n        allow write: if isAuthenticated() && isAdminOrSupervisor(request.auth.uid);\n    }\n  }\n}\n"}]}}
